# ===========================================
# tag-mule - Gateway/Proxy de IA unificado
# ===========================================

# --- Torre Debian (hardware local) ---
TORRE_IP=192.168.1.100
TORRE_MAC=AA:BB:CC:DD:EE:FF
SSH_USER=tu_usuario

# --- Servidor Proxy ---
PROXY_PORT=8080

# --- Proveedor Externo (opcional) ---
# Si es true, se salta WoL/Ollama y envía directamente al proveedor externo.
USE_EXTERNAL_PROVIDER=false
EXTERNAL_API_URL=https://api.openai.com
EXTERNAL_API_KEY=sk-tu-api-key-aqui

# --- Tiempos (en segundos) ---
# Tiempo máximo de espera para que la torre despierte vía WoL
WAKE_TIMEOUT=600
# Tiempo de cortesía antes de suspender la torre (espera más lotes)
SUSPEND_DELAY=120
# Intervalo de polling mientras se espera que Ollama responda
WAKE_POLL_INTERVAL=2
# Puerto donde corre Ollama en la torre
OLLAMA_PORT=11434

# --- Base de datos ---
# Ruta al archivo SQLite donde se persisten los trabajos pendientes.
# El directorio se crea automáticamente si no existe.
DB_PATH=./data/tag-mule.db